{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Radianite",
  "version": "0.1.4",
  "identifier": "dev.radcolor.radianite",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Radianite",
        "width": 1152,
        "height": 768,
        "minWidth": 1024,
        "minHeight": 600,
        "backgroundColor": "#202024",
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "compression": "lzma",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "startMenuFolder": "Radianite",
        "installerHooks": "windows/installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5QTQzNTJDQTZFRkM2RApSV1J0L0c3S1VrT2FCVFJkeWR6K1pKei92azlSdUVRZ2pIZXR1WVcwOHZ5SlludXF6UXFyU0I4SQo=",
      "endpoints": [
        "https://github.com/radcolor-dev/radianite_val/releases/latest/download/latest.json"
      ]
    }
  }
}
