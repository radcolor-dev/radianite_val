{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "radianite",
  "version": "0.1.0",
  "identifier": "dev.radcolor.radianite",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Radianite",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDNkE0OTAzRTFEMjMzNTMKUldSVE05TGhBMGxxVE83elZCUFkzWnU0MFg3NEF3VEhQRmNPTHZoejlPRU1uYnBibC8yZFU5cHgK",
      "endpoints": [
        "https://github.com/radcolor-dev/radiante_val/releases/latest/download/latest.json"
      ]
    }
  }
}
